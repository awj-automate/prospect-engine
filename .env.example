# ─── Database (Neon POOLED connection string) ────────────────────────────────
# Use the *pooled* string (host contains "-pooler"). drizzle + postgres-js.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ─── LeadShark / Apex ────────────────────────────────────────────────────────
LEADSHARK_API_KEY="ls_live_xxx"

# ─── Anthropic (research brief synthesis) ────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-xxx"

# ─── Web research provider ───────────────────────────────────────────────────
# One of: perplexity | linkup
WEB_RESEARCH_PROVIDER="perplexity"
PERPLEXITY_API_KEY="pplx-xxx"
LINKUP_API_KEY="linkup-xxx"

# ─── Contact enrichment (AnyMail Finder) ─────────────────────────────────────
ANYMAILFINDER_API_KEY="amf-xxx"

# ─── Auth / cron ─────────────────────────────────────────────────────────────
# Single shared password for the cookie gate.
APP_PASSWORD="change-me-to-a-long-random-string"
# Shared secret required by internal/cron-invoked routes (x-cron-secret header).
CRON_SECRET="another-long-random-string"

# ─── Scheduling / rate windows ───────────────────────────────────────────────
TZ="Europe/London"
DAILY_PERSON_ENRICH_CAP="50"
DAILY_COMPANY_ENRICH_CAP="50"
ENRICH_WINDOW_START_HOUR="8"
ENRICH_WINDOW_END_HOUR="20"
PERSON_ENRICH_SECTIONS="about,experience,education"
